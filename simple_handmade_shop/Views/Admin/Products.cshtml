@model IEnumerable<simple_handmade_shop.Models.Product>

<h1>Products</h1>
<div class="createProduct">
    <a class="btn btn-primary w-100" asp-controller="Admin" asp-action="Create">Create New Product</a>
</div>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Photo</th>
            <th>Name</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr class="align-middle">
                <td>@product.Id</td>
                <td><img src="@product.ImageUrl" alt="@product.Name" style="max-width: 100px;" /></td>
                <td>@product.Name</td>
                <td>@product.Price</td>
                <td>
                    <a asp-controller="Admin" asp-action="Edit" class="btn btn-info" asp-route-id="@product.Id">Edit</a> |
                    <a asp-controller="Admin" asp-action="Delete" class="btn btn-danger" asp-route-id="@product.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
